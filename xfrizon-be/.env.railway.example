# Railway Raw Variables template for xfrizon-be
# Copy into Railway -> Service -> Variables -> Raw Editor

SPRING_PROFILES_ACTIVE=prod
PUBLIC_BASE_URL=https://xfrizon.up.railway.app

# Cloudinary
CLOUDINARY_ENABLED=true
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=xfrizon

# Required backend/runtime vars
JWT_SECRET=replace_with_secure_secret
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Usually injected by Railway MySQL service link
MYSQLHOST=
MYSQLPORT=
MYSQLDATABASE=
MYSQLUSER=
MYSQLPASSWORD=
