# Stripe Configuration
# Get your Stripe public key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxx

# API Configuration
# Base URL for backend API
VITE_API_BASE_URL=http://localhost:8081/api/v1

# Admin AI blog assistant endpoint (backend routed)
# Keep API keys on the server. Frontend calls this route only.
VITE_ADMIN_AI_CHAT_ENDPOINT=/admin/ai/blog-assistant/chat

# Public site URL for canonical/share fallbacks (set your domain in production)
VITE_SITE_URL=https://xfrizon.up.railway.app

# Google OAuth sign-up integration (optional)
# Optional absolute backend origin override for OAuth start redirect
# Useful when API base URL is relative (e.g. /api/v1) and frontend runs on a different origin
# Example (dev): VITE_OAUTH_BACKEND_ORIGIN=http://localhost:8081
VITE_OAUTH_BACKEND_ORIGIN=
# Backend endpoint that starts Google OAuth flow
VITE_GOOGLE_OAUTH_START_PATH=/oauth2/authorization/google
# Backend endpoint that finalizes account after Google callback
VITE_GOOGLE_OAUTH_COMPLETE_PATH=/auth/oauth/google/complete-signup

# Environment
VITE_ENV=development
