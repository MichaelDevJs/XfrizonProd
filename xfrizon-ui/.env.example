# Stripe Configuration
# Get your Stripe public key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxx

# API Configuration
# Base URL for backend API
VITE_API_BASE_URL=http://localhost:8081/api/v1

# Admin AI blog assistant endpoint (backend routed)
# Keep API keys on the server. Frontend calls this route only.
VITE_ADMIN_AI_CHAT_ENDPOINT=/admin/ai/blog-assistant/chat

# Public site URL for canonical/share fallbacks (set your domain in production)
VITE_SITE_URL=https://xfrizon.up.railway.app

# Environment
VITE_ENV=development
